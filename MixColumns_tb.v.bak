// ??nh ngh?a thang ?o th?i gian: 1ns cho m?i b??c mō ph?ng, ?? chķnh xįc 1ps
`timescale 1ns / 1ps

module tb_mix_columns();

    // 1. Khai bįo tķn hi?u
    reg  [127:0] tb_state_in;    // Input dłng reg
    wire [127:0] tb_state_out;   // Output dłng wire

    // 2. Kh?i t?o module c?n test (G?i lą DUT - Device Under Test)
    // Įnh x? tķn hi?u c?a Testbench vąo cįc c?ng c?a module mix_columns
    mix_columns dut (
        .state_in(tb_state_in),
        .state_out(tb_state_out)
    );

    // 3. Kh?i t?o tķn hi?u kķch thķch (Stimulus)
    initial begin
        // In ra tiźu ?? c?t trźn c?a s? Console (Transcript)
        $display("===============================================================");
        $display("                 TESTBENCH KH?I MIX COLUMNS AES                ");
        $display("===============================================================");
        $display("Thoi gian | State Input                      | State Output");
        $display("---------------------------------------------------------------");

        // --- TEST CASE 1: Test vector chu?n t? tąi li?u FIPS 197 c?a NIST ---
        
        // C?p giį tr? ??u vąo (Hexadecimal)
        tb_state_in = 128'hd4bf5d30_e0b452ae_b84111f1_1e2798e5;
        
        // ??i 10 nanosecond ?? m?ch t? h?p tķnh toįn xong
        #10; 
        
        // In k?t qu? ra mąn hģnh (Hąm $display ho?t ??ng gi?ng printf trong C)
        // %0t: Th?i gian hi?n t?i, %h: In d?ng Hex
        $display("%0t ns    | %h | %h", $time, tb_state_in, tb_state_out);
        
        // Ki?m tra t? ??ng (Self-checking)
        if (tb_state_out == 128'h046681e5_e0cb199a_48f8d37a_2806264c) begin
            $display("\n=> KET QUA: PASSED! Mach hoat dong dung chuan NIST.");
        end else begin
            $display("\n=> KET QUA: FAILED! Ket qua khong khop voi NIST vector.");
            $display("Gia tri mong doi : 046681e5e0cb199a48f8d37a2806264c");
            $display("Gia tri thuc te  : %h", tb_state_out);
        end

        // --- TEST CASE 2: Ma tr?n toąn s? 0 ---
        tb_state_in = 128'h00000000_00000000_00000000_00000000;
        #10;
        $display("%0t ns    | %h | %h", $time, tb_state_in, tb_state_out);

        // --- TEST CASE 3: Cįc giį tr? ng?u nhiźn ?? ki?m tra góc (Edge cases) ---
        tb_state_in = 128'hffffffff_ffffffff_ffffffff_ffffffff;
        #10;
        $display("%0t ns    | %h | %h", $time, tb_state_in, tb_state_out);

        $display("===============================================================");
        
        // K?t thśc mō ph?ng
        $stop; 
    end

endmodule